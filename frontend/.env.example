# VITE_ prefix exposes the variable to the browser bundle
VITE_GOOGLE_MAPS_KEY=your_google_maps_javascript_api_key_here

# Leave empty for local dev (Vite proxies /api → localhost:3001).
# Set to your deployed backend URL for production, e.g.:
# VITE_API_URL=https://venue-finder-api.onrender.com
VITE_API_URL=
