# ── Shared: copy this file to .env at the project root for Docker ─────────────
# For local dev without Docker, copy the relevant sections to:
#   backend/.env   (GOOGLE_PLACES_API_KEY, NEBIUS_API_KEY, MONGODB_URI, PORT)
#   frontend/.env  (VITE_GOOGLE_MAPS_KEY)

GOOGLE_PLACES_API_KEY=your_google_places_api_key_here
NEBIUS_API_KEY=your_nebius_api_key_here
VITE_GOOGLE_MAPS_KEY=your_google_maps_javascript_api_key_here

# MongoDB is managed by docker-compose automatically.
# Override here only if pointing at an external cluster:
# MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/venue-finder
